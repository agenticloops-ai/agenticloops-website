---
import Layout from '../layouts/Layout.astro';
import { Header, Hero, About, TutorialsPreview, LearnPreview, PatternsPreview, Subscribe, Footer } from '../components/Islands';
import ThemeScript from '../components/ThemeScript.astro';
---

<Layout title="Agentic Loops">
  <ThemeScript />
  <Header client:load />
  <main>
    <Hero client:load />
    <About client:visible />
    <TutorialsPreview client:visible />
    <LearnPreview client:visible />
    <PatternsPreview client:visible />
    <Subscribe client:visible />
  </main>
  <Footer client:visible />
</Layout>
