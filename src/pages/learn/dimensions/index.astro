---
import LearnLayout from '../../../layouts/LearnLayout.astro';
import { Header, Footer, DimensionGrid } from '../../../components/Islands';
---

<LearnLayout
	title="Dimensions | Learn | Agentic Loops"
	breadcrumbs={[{ label: 'Dimensions' }]}
>
	<Header client:load slot="header" />

	<section class="section relative overflow-hidden">
		<div class="container">
			<div class="text-center mb-14">
				<div class="flex items-center justify-center gap-4 mb-6">
					<div class="w-10 h-0.5" style="background: var(--color-accent-primary)"></div>
					<span class="badge">dimensions</span>
					<div class="w-10 h-0.5" style="background: var(--color-accent-primary)"></div>
				</div>

				<h1 class="mb-6">
					Capability Dimensions
				</h1>

				<p class="hero-tagline max-w-[600px] mx-auto">
					Eight axes of competence for building production-grade agentic systems.
					Each dimension has 5 levels — from beginner to production expert.
				</p>
			</div>

			<DimensionGrid client:visible />
		</div>
	</section>

	<Footer client:load slot="footer" />
</LearnLayout>
